{
    "$schema": "https://github.com/AvengeMedia/DankMaterialShell/raw/refs/heads/master/PLUGINS/plugin-schema.json",
    "id": "dankSystemDoctor",
    "name": "Dank System Doctor",
    "description": "AI-powered system health monitor. CPU, RAM, disk, GPU, temp; pending updates (apt/dnf/pacman/brew); one-click maintenance and snapshot guardrails; Ollama diagnostics with triage playbooks.",
    "version": "1.1.0",
    "author": "noxius",
    "icon": "monitor_heart",
    "type": "widget",
    "capabilities": [
        "system-monitor",
        "ai-diagnostics",
        "log-viewer",
        "process-manager",
        "updates",
        "maintenance"
    ],
    "component": "./DankSystemDoctor.qml",
    "settings": "./DankSystemDoctorSettings.qml",
    "requires_dms": ">=1.4.0",
    "requires": [
        "bash",
        "journalctl",
        "ps",
        "free",
        "df"
    ],
    "permissions": [
        "settings_read",
        "settings_write",
        "process"
    ]
}
